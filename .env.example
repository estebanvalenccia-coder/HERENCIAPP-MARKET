# Frontend
# En producción usa la URL real de tu backend, por ejemplo https://api.tudominio.com
VITE_API_URL=

# Backend
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://www.herenciamarket.es,https://herenciamarket.es

# Supabase backend real. Usa SERVICE_ROLE_KEY solo en el servidor, nunca en el frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe real. La secret key y el webhook secret solo van en backend.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin real. Cambia estos valores antes de producción.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
