# Frontend
# En producción usa la URL real de tu backend con https:// delante.
VITE_API_URL=https://herenciapp-market-production.up.railway.app

# Backend
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://www.herenciamarket.es,https://herenciamarket.es,https://herenciapp-market.vercel.app

# Supabase backend real. Usa SERVICE_ROLE_KEY solo en el servidor, nunca en el frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe real. La secret key y el webhook secret solo van en backend.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin real. Cambia estos valores antes de producción.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Emails de pedido. ADMIN_ORDER_EMAIL recibe las notificaciones internas.
RESEND_API_KEY=
EMAIL_FROM=Herencia Market <onboarding@resend.dev>
ADMIN_ORDER_EMAIL=
STORE_EMAIL=herenciafloristeria@gmail.com
